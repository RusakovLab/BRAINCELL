_comp = mmAllComps.o(0)
_addHomogenVarsInfoToBiophysComp1(_comp)    // "Soma"

_comp = mmAllComps.o(1)
_addHomogenVarsInfoToBiophysComp2(_comp)    // "Dendrites"

_comp = mmAllComps.o(2)
_addHomogenVarsInfoToBiophysComp3(_comp)    // "Axon"

_comp = mmAllComps.o(3)
_addHomogenVarsInfoToBiophysComp4(_comp)    // "Spine Neck"

_comp = mmAllComps.o(4)
_addHomogenVarsInfoToBiophysComp5(_comp)    // "Spine Head"

_comp = mmAllComps.o(5)
_addHomogenVarsInfoToBiophysComp6(_comp)    // "Extra Cell #1"

for eachItemInList(_comp, mmAllComps) {
    _comp.initHomogenBiophysics()
}

