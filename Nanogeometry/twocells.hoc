begintemplate ReducedSpeciesLibrary

    public copyGlobalVarsToModParams, packToVec, getSpeciesFlatIdxForModInterface
    
    external stringsEqual, codeContractViolation
    
    
    proc copyGlobalVarsToModParams() {
        execute("naoinit_OutsideInDiffHelper = nao0_na_ion")
        execute("koinit_OutsideInDiffHelper = ko0_k_ion")
        execute("caoinit_OutsideInDiffHelper = cao0_ca_ion")
        execute("cloinit_OutsideInDiffHelper = clo0_cl_ion")
        execute("achoinit_OutsideInDiffHelper = acho0_ach_ion")
        execute("gluoinit_OutsideInDiffHelper = gluo0_glu_ion")
        execute("gabaoinit_OutsideInDiffHelper = gabao0_gaba_ion")
        execute("frapionoinit_OutsideInDiffHelper = frapiono0_frapion_ion")
        execute("ip3oinit_OutsideInDiffHelper = ip3o0_ip3_ion")
        execute("extra1oinit_OutsideInDiffHelper = extra1o0_extra1_ion")
        execute("extra2oinit_OutsideInDiffHelper = extra2o0_extra2_ion")
    }
    
    obfunc packToVec() { localobj vec
        vec = new Vector(34)
        vec.x[0] = 11.0
        vec.x[1] = 1.0
        vec.x[2] = 0.0
        vec.x[3] = 1000.0
        vec.x[4] = 1.0
        vec.x[5] = 0.0
        vec.x[6] = 8000.0
        vec.x[7] = 1.0
        vec.x[8] = 0.0
        vec.x[9] = 5000.0
        vec.x[10] = 1.0
        vec.x[11] = 0.0
        vec.x[12] = 2000.0
        vec.x[13] = 0.3
        vec.x[14] = 0.0
        vec.x[15] = 1000.0
        vec.x[16] = 0.3
        vec.x[17] = 0.0
        vec.x[18] = 1000.5
        vec.x[19] = 0.3
        vec.x[20] = 0.0
        vec.x[21] = 1000.5
        vec.x[22] = 1.0
        vec.x[23] = 0.0
        vec.x[24] = 1000.5
        vec.x[25] = 1.0
        vec.x[26] = 0.0
        vec.x[27] = 1000.5
        vec.x[28] = 1.0
        vec.x[29] = 0.0
        vec.x[30] = 1234.5
        vec.x[31] = 1.0
        vec.x[32] = 0.0
        vec.x[33] = 1234.5
        return vec
    }
    
    func getSpeciesFlatIdxForModInterface() { local spcCatIdx
        strdef species
        
        spcCatIdx = $1
        species = $s2
        
        if (spcCatIdx == 0) {
            if (stringsEqual(species, "Na+")) {
                return 0
            } else if (stringsEqual(species, "K+")) {
                return 1
            } else if (stringsEqual(species, "Ca2+")) {
                return 2
            } else if (stringsEqual(species, "Cl-")) {
                return 3
            }
        } else if (spcCatIdx == 1) {
            if (stringsEqual(species, "ACh+")) {
                return 4
            } else if (stringsEqual(species, "GLU-")) {
                return 5
            } else if (stringsEqual(species, "GABA")) {
                return 6
            }
        } else if (spcCatIdx == 2) {
            if (stringsEqual(species, "FRAP+")) {
                return 7
            } else if (stringsEqual(species, "Ins3P+")) {
                return 8
            }
        } else if (spcCatIdx == 3) {
            if (stringsEqual(species, "Extra1Ion+")) {
                return 9
            } else if (stringsEqual(species, "Extra2Ion-")) {
                return 10
            }
        }
        codeContractViolation()
    }
    
endtemplate ReducedSpeciesLibrary

objref speciesLibrary
speciesLibrary = new ReducedSpeciesLibrary()

