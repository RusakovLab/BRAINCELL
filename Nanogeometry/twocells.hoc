    mechStd = new MechanismStandard("kdr", 1)    // PARAMETER
    mechStd.set("gkdrbar_kdr", 0.01)    // (mho/cm2)
    comp.mechStds[mechIdxs.x[17]][0] = mechStd
    
    mechStd = new MechanismStandard("na3", 1)    // PARAMETER
    mechStd.set("gbar_na3", 0.032)    // (mho/cm2)
    comp.mechStds[mechIdxs.x[18]][0] = mechStd
}

// "Spine Head"
proc _addHomogenVarsInfoToBiophysComp5() { local idx localobj comp, mechIdxs, mechStd
    comp = $o1
    
    mechIdxs = new Vector(19)
    mechIdxs.x[0] = mth.getMechIdx(0, "morphology")
    mechIdxs.x[1] = mth.getMechIdx(0, "capacitance")
    mechIdxs.x[2] = mth.getMechIdx(0, "pas")
    mechIdxs.x[3] = mth.getMechIdx(0, "na_ion")
    mechIdxs.x[4] = mth.getMechIdx(0, "k_ion")
    mechIdxs.x[5] = mth.getMechIdx(0, "glu_ion")
    mechIdxs.x[6] = mth.getMechIdx(0, "ca_ion")
    mechIdxs.x[7] = mth.getMechIdx(0, "frapion_ion")
    mechIdxs.x[8] = mth.getMechIdx(0, "gaba_ion")
    mechIdxs.x[9] = mth.getMechIdx(0, "GABA_tonic_gabao")
    mechIdxs.x[10] = mth.getMechIdx(0, "cl_ion")
    mechIdxs.x[11] = mth.getMechIdx(0, "ach_ion")
    mechIdxs.x[12] = mth.getMechIdx(0, "ip3_ion")
    mechIdxs.x[13] = mth.getMechIdx(0, "extra1_ion")
    mechIdxs.x[14] = mth.getMechIdx(0, "extra2_ion")
    mechIdxs.x[15] = mth.getMechIdx(0, "OutsideInDiffHelper")
    mechIdxs.x[16] = mth.getMechIdx(0, "kap")
    mechIdxs.x[17] = mth.getMechIdx(0, "kdr")
    mechIdxs.x[18] = mth.getMechIdx(0, "na3")
    
    for idx = 0, 18 {
        comp.isMechInserted[mechIdxs.x[idx]] = 1
    }
    
    mechStd = new MechanismStandard("morphology", 1)    // PARAMETER
    mechStd.set("diam", math.nan)
    comp.mechStds[mechIdxs.x[0]][0] = mechStd
    
    mechStd = new MechanismStandard("pas", 1)    // PARAMETER
    mechStd.set("g_pas", 7.142857142857143e-05)    // (S/cm2)
    mechStd.set("e_pas", -65.0)    // (mV)
    comp.mechStds[mechIdxs.x[2]][0] = mechStd
    
    mechStd = new MechanismStandard("GABA_tonic_gabao", 1)    // PARAMETER
    mechStd.set("g_max_GABA_tonic_gabao", 0.001)    // (S/cm2)
    comp.mechStds[mechIdxs.x[9]][0] = mechStd
    
    mechStd = new MechanismStandard("kap", 1)    // PARAMETER
    mechStd.set("gkabar_kap", 0.048)    // (mho/cm2)
    comp.mechStds[mechIdxs.x[16]][0] = mechStd
    
    mechStd = new MechanismStandard("kdr", 1)    // PARAMETER
    mechStd.set("gkdrbar_kdr", 0.01)    // (mho/cm2)
    comp.mechStds[mechIdxs.x[17]][0] = mechStd
    
    mechStd = new MechanismStandard("na3", 1)    // PARAMETER
    mechStd.set("gbar_na3", 0.032)    // (mho/cm2)
    comp.mechStds[mechIdxs.x[18]][0] = mechStd
}

